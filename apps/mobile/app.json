{\n  "expo": {\n    "name": "FaceFlow",\n    "slug": "faceflow",\n    "version": "1.0.0",\n    "orientation": "portrait",\n    "icon": "./assets/icon.png",\n    "userInterfaceStyle": "automatic",\n    "splash": {\n      "image": "./assets/splash.png",\n      "resizeMode": "contain",\n      "backgroundColor": "#ffffff"\n    },\n    "assetBundlePatterns": [\n      "**/*"\n    ],\n    "ios": {\n      "supportsTabletMode": true,\n      "bundleIdentifier": "com.faceflow.app",\n      "buildNumber": "1.0.0"\n    },\n    "android": {\n      "adaptiveIcon": {\n        "foregroundImage": "./assets/adaptive-icon.png",\n        "backgroundColor": "#ffffff"\n      },\n      "package": "com.faceflow.app",\n      "versionCode": 1\n    },\n    "web": {\n      "favicon": "./assets/favicon.png"\n    },\n    "plugins": [\n      [\n        "expo-camera",\n        {\n          "cameraPermission": "Allow FaceFlow to access your camera"\n        }\n      ],\n      [\n        "expo-image-picker",\n        {\n          "photosPermission": "Allow FaceFlow to access your photos"\n        }\n      ],\n      [\n        "expo-notifications",\n        {\n          "icon": "./assets/notification-icon.png"\n        }\n      ]\n    ],\n    "extra": {\n      "eas": {\n        "projectId": "your-eas-project-id"\n      }\n    }\n  }\n}\n